# Copy to .env. .env is gitignored.
# Required for evaluation — pick at least one VLM provider.
FAL_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: dataset-build dependencies (fal-ai for NB2 + GPT-Image-2)
# FAL_KEY (above) is enough.

# Optional: plug in your own storage backend for image hosting.
# Default is local (images stay on disk; FastAPI server serves them).
# Implement bench.utils.storage.Storage and point at it:
# BENCH_STORAGE_BACKEND=mypkg.r2.R2Storage
